<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingVertical="16dp"
    android:background="@color/surface_white">

    <!-- 基础打卡周期标题 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/dialog_title_schedule"
        android:textStyle="bold"
        android:textColor="@color/text_dark"
        android:textSize="15sp"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/dialog_desc_schedule"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="12dp"
        android:lineSpacingMultiplier="1.3" />

    <!-- 星期切换小球 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="24dp">

        <CheckBox
            android:id="@+id/cb_mon"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:button="@null"
            android:background="@drawable/bg_week_button"
            android:textColor="@color/color_week_button_text"
            android:text="@string/week_mon"
            android:gravity="center"
            android:textStyle="bold"
            android:textSize="12sp"
            android:layout_marginHorizontal="4dp" />

        <CheckBox
            android:id="@+id/cb_tue"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:button="@null"
            android:background="@drawable/bg_week_button"
            android:textColor="@color/color_week_button_text"
            android:text="@string/week_tue"
            android:gravity="center"
            android:textStyle="bold"
            android:textSize="12sp"
            android:layout_marginHorizontal="4dp" />

        <CheckBox
            android:id="@+id/cb_wed"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:button="@null"
            android:background="@drawable/bg_week_button"
            android:textColor="@color/color_week_button_text"
            android:text="@string/week_wed"
            android:gravity="center"
            android:textStyle="bold"
            android:textSize="12sp"
            android:layout_marginHorizontal="4dp" />

        <CheckBox
            android:id="@+id/cb_thu"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:button="@null"
            android:background="@drawable/bg_week_button"
            android:textColor="@color/color_week_button_text"
            android:text="@string/week_thu"
            android:gravity="center"
            android:textStyle="bold"
            android:textSize="12sp"
            android:layout_marginHorizontal="4dp" />

        <CheckBox
            android:id="@+id/cb_fri"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:button="@null"
            android:background="@drawable/bg_week_button"
            android:textColor="@color/color_week_button_text"
            android:text="@string/week_fri"
            android:gravity="center"
            android:textStyle="bold"
            android:textSize="12sp"
            android:layout_marginHorizontal="4dp" />

        <CheckBox
            android:id="@+id/cb_sat"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:button="@null"
            android:background="@drawable/bg_week_button"
            android:textColor="@color/color_week_button_text"
            android:text="@string/week_sat"
            android:gravity="center"
            android:textStyle="bold"
            android:textSize="12sp"
            android:layout_marginHorizontal="4dp" />

        <CheckBox
            android:id="@+id/cb_sun"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:button="@null"
            android:background="@drawable/bg_week_button"
            android:textColor="@color/color_week_button_text"
            android:text="@string/week_sun"
            android:gravity="center"
            android:textStyle="bold"
            android:textSize="12sp"
            android:layout_marginHorizontal="4dp" />
    </LinearLayout>

    <!-- 上班时间配置 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/dialog_title_morning_random"
        android:textStyle="bold"
        android:textColor="@color/text_dark"
        android:textSize="15sp"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/dialog_desc_morning_random"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="12dp"
        android:lineSpacingMultiplier="1.3" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <TextView
            android:id="@+id/tv_morning_start"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:paddingVertical="12dp"
            android:background="@drawable/bg_time_picker"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/primary_blue"
            android:text="@string/default_morning_start"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/dialog_range_separator"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"/>

        <TextView
            android:id="@+id/tv_morning_end"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:paddingVertical="12dp"
            android:background="@drawable/bg_time_picker"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/primary_blue"
            android:text="@string/default_morning_end"/>
    </LinearLayout>

    <!-- 下班时间配置 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/dialog_title_afternoon_random"
        android:textStyle="bold"
        android:textColor="@color/text_dark"
        android:textSize="15sp"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/dialog_desc_afternoon_random"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="12dp"
        android:lineSpacingMultiplier="1.3" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/tv_afternoon_start"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:paddingVertical="12dp"
            android:background="@drawable/bg_time_picker"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/afternoon_orange"
            android:text="@string/default_afternoon_start"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/dialog_range_separator"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"/>

        <TextView
            android:id="@+id/tv_afternoon_end"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:paddingVertical="12dp"
            android:background="@drawable/bg_time_picker"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/afternoon_orange"
            android:text="@string/default_afternoon_end"/>
    </LinearLayout>

</LinearLayout>
