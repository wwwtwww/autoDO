<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="autoDO 运行中心"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="30dp"/>

    <Button
        android:id="@+id/btn_enable_accessibility"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🛡️ 开启系统无障碍权限 (必须)"
        android:layout_marginBottom="15dp"/>

    <Button
        android:id="@+id/btn_test_unlock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🧪 模拟测试：唤醒与解锁" />

    <Button
        android:id="@+id/btn_test_clock_in"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🧪 模拟测试：极速打卡流"
        android:layout_marginTop="15dp"/>

    <Button
        android:id="@+id/btn_schedule_tasks"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🚀 启动自动打卡守护进程"
        android:backgroundTint="#FF4CAF50"
        android:textColor="#FFFFFF"
        android:layout_marginTop="30dp"/>
        
    <Button
        android:id="@+id/btn_view_logs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📅 查看历史打卡记录"
        android:layout_marginTop="15dp"/>
        
    <Button
        android:id="@+id/btn_config_time"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚙️ 配置随机打卡时间段"
        android:layout_marginTop="15dp"/>
        
</LinearLayout>
