<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- 标题区 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/app_name"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/primary_blue" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_subtitle"
                android:textSize="12sp"
                android:textColor="@color/primary_blue"
                android:background="@color/light_blue_bg"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 状态主看板 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_global_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tv_global_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/status_default"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/error_red_dark"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_global_status_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/status_desc_default"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:lineSpacingMultiplier="1.3" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 第一组：核心打卡控制 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/section_core"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/surface_white"
            app:strokeColor="@color/divider_gray"
            app:strokeWidth="1dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_schedule_tasks"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="@string/btn_start_guard"
                    android:textColor="@color/status_green"
                    android:textSize="15sp"
                    android:gravity="start|center_vertical"
                    android:paddingStart="20dp"
                    app:iconPadding="10dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider_gray"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_config_time"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/btn_config_time"
                    android:textColor="@color/text_dark"
                    android:textSize="14sp"
                    android:gravity="start|center_vertical"
                    android:paddingStart="20dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider_gray"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_manage_exceptions"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/btn_manage_exceptions"
                    android:textColor="@color/text_dark"
                    android:textSize="14sp"
                    android:gravity="start|center_vertical"
                    android:paddingStart="20dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider_gray"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_view_logs"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/btn_view_logs"
                    android:textColor="@color/text_dark"
                    android:textSize="14sp"
                    android:gravity="start|center_vertical"
                    android:paddingStart="20dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 第二组：权限管理 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/section_permissions"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/surface_white"
            app:strokeColor="@color/divider_gray"
            app:strokeWidth="1dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="8dp">

                <!-- 无障碍 -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/btn_enable_accessibility"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:background="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingHorizontal="20dp">

                    <TextView
                        android:id="@+id/tv_accessibility_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/title_accessibility"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/tv_status_accessibility"
                        app:layout_constraintBottom_toTopOf="@id/tv_accessibility_desc"
                        app:layout_constraintVertical_chainStyle="packed" />

                    <TextView
                        android:id="@+id/tv_accessibility_desc"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/desc_accessibility"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="2dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_accessibility_title"
                        app:layout_constraintEnd_toStartOf="@id/tv_status_accessibility"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <TextView
                        android:id="@+id/tv_status_accessibility"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/status_unauthorized"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/status_red"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider_light"/>

                <!-- 自启动 -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/btn_auto_start"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:background="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingHorizontal="20dp">

                    <TextView
                        android:id="@+id/tv_autostart_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/title_auto_start"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/tv_status_autostart"
                        app:layout_constraintBottom_toTopOf="@id/tv_autostart_desc"
                        app:layout_constraintVertical_chainStyle="packed" />

                    <TextView
                        android:id="@+id/tv_autostart_desc"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/desc_auto_start"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="2dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_autostart_title"
                        app:layout_constraintEnd_toStartOf="@id/tv_status_autostart"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <TextView
                        android:id="@+id/tv_status_autostart"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/status_go_config"
                        android:textSize="13sp"
                        android:textColor="@color/primary_blue"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider_light"/>

                <!-- 电池优化 -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/btn_battery_optimization"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:background="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingHorizontal="20dp">

                    <TextView
                        android:id="@+id/tv_battery_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/title_battery"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/tv_status_battery"
                        app:layout_constraintBottom_toTopOf="@id/tv_battery_desc"
                        app:layout_constraintVertical_chainStyle="packed" />

                    <TextView
                        android:id="@+id/tv_battery_desc"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/desc_battery"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="2dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_battery_title"
                        app:layout_constraintEnd_toStartOf="@id/tv_status_battery"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <TextView
                        android:id="@+id/tv_status_battery"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/status_not_closed"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/status_red"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider_light"/>

                <!-- 悬浮窗 -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layout_overlay"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:paddingHorizontal="20dp">

                    <TextView
                        android:id="@+id/tv_overlay_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/title_overlay"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/tv_status_overlay"
                        app:layout_constraintBottom_toTopOf="@id/tv_overlay_desc"
                        app:layout_constraintVertical_chainStyle="packed" />

                    <TextView
                        android:id="@+id/tv_overlay_desc"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/desc_overlay"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="2dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_overlay_title"
                        app:layout_constraintEnd_toStartOf="@id/tv_status_overlay"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <TextView
                        android:id="@+id/tv_status_overlay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/status_unauthorized"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/status_red"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider_light"/>

                <!-- 精确闹钟 -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layout_alarm"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:paddingHorizontal="20dp">

                    <TextView
                        android:id="@+id/tv_alarm_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/title_alarm"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/tv_status_alarm"
                        app:layout_constraintBottom_toTopOf="@id/tv_alarm_desc"
                        app:layout_constraintVertical_chainStyle="packed" />

                    <TextView
                        android:id="@+id/tv_alarm_desc"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/desc_alarm"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="2dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_alarm_title"
                        app:layout_constraintEnd_toStartOf="@id/tv_status_alarm"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <TextView
                        android:id="@+id/tv_status_alarm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/status_not_ready"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/status_red"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider_light"/>

                <!-- 前台保活通知开关 -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_keepalive"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/btn_keepalive"
                    android:textColor="@color/keepalive_text"
                    android:textSize="14sp"
                    android:gravity="start|center_vertical"
                    android:paddingStart="20dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 第三组：测试功能 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/section_test"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/surface_white"
            app:strokeColor="@color/divider_gray"
            app:strokeWidth="1dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/test_warning_title"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/warning_red"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/test_warning_desc"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="16dp"
                    android:lineSpacingMultiplier="1.3"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_test_unlock"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:text="@string/btn_test_unlock"
                        android:textSize="13sp"
                        android:textColor="@color/primary_blue"
                        app:strokeColor="@color/primary_blue"
                        app:cornerRadius="10dp"
                        android:layout_marginEnd="4dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_test_clock_in"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:text="@string/btn_test_clock_in"
                        android:textSize="13sp"
                        android:textColor="@color/primary_blue"
                        app:strokeColor="@color/primary_blue"
                        app:cornerRadius="10dp"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
