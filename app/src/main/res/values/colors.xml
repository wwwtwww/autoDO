<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- === 基础调色板（保留系统默认） === -->
    <color name="purple_200">#FFBB86FC</color>
    <color name="purple_500">#FF6200EE</color>
    <color name="purple_700">#FF3700B3</color>
    <color name="teal_200">#FF03DAC5</color>
    <color name="teal_700">#FF018786</color>
    <color name="black">#FF000000</color>
    <color name="white">#FFFFFFFF</color>

    <!-- === 语义化颜色常量 === -->

    <!-- 页面 / 卡片底色 -->
    <color name="app_background">#F5F7FA</color>
    <color name="surface_white">#FFFFFF</color>

    <!-- 品牌蓝 -->
    <color name="primary_blue">#1A73E8</color>
    <color name="light_blue_bg">#E8F0FE</color>

    <!-- 文字层级
         ┌─ text_primary:  标题 / 正文第一层（WCAG AA @ 白底 = 对比度 16.7:1）
         ├─ text_secondary: 副标题 / 描述文字（对比度 7.4:1，远超 AA 4.5:1 门槛）
         └─ text_hint:      辅助说明 / placeholder（对比度 4.6:1，满足 AA）
    -->
    <color name="text_primary">#1F1F1F</color>
    <color name="text_secondary">#3C4043</color>
    <color name="text_hint">#6D7175</color>

    <!-- 旧别名（向后兼容布局引用） -->
    <color name="text_dark">@color/text_primary</color>
    <color name="text_gray">@color/text_secondary</color>

    <!-- 分割线 -->
    <color name="divider_gray">#DADCE0</color>
    <color name="divider_light">#EEEEEE</color>

    <!-- 状态色 -->
    <color name="status_green">#0D904F</color>
    <color name="status_red">#D93025</color>
    <color name="success_green">#137333</color>
    <color name="success_green_bg">#E6F4EA</color>
    <color name="error_red_dark">#B3261E</color>
    <color name="error_bg">#FCE8E6</color>

    <!-- 下午时段橙色 -->
    <color name="afternoon_orange">#C75400</color>

    <!-- 保活开关 -->
    <color name="keepalive_on_bg">#FFF3E0</color>
    <color name="keepalive_off_bg">#FFF8E1</color>
    <color name="keepalive_text">#E65100</color>

    <!-- 日志 -->
    <color name="log_text_gray">@color/text_secondary</color>

    <!-- 警告 -->
    <color name="warning_red">#C62828</color>

    <!-- 星期小球 - 未选中态背景 -->
    <color name="week_btn_unselected_bg">#E8EAED</color>
    <!-- 星期小球 - 未选中态文字 -->
    <color name="week_btn_unselected_text">#3C4043</color>
</resources>
